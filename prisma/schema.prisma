generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CUSTOMER
  ADMIN
}

enum DrawType {
  POWERBALL
  MEGA_MILLIONS
}

enum OrderStatus {
  PENDING_PAYMENT
  PENDING_APPROVAL
  APPROVED
  TICKET_UPLOADED
  MATCHED
  REJECTED
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  phone        String?
  lineId       String?
  passwordHash String
  role         Role     @default(CUSTOMER)
  createdAt    DateTime @default(now())

  walletBalance       Decimal  @default(0) @db.Decimal(12, 2)

  orders              Order[]
  passwordResetTokens PasswordResetToken[]
  walletTransactions  WalletTransaction[]
  referrerProfile     ReferrerProfile?
  referralAsReferred  UserReferral?        @relation("ReferredUser")
  referralsGiven      UserReferral[]       @relation("ReferrerUser")
  auditLogs           AuditLog[]           @relation("AuditAdmin")
}

model Draw {
  id        String   @id @default(cuid())
  type      DrawType
  drawDate  DateTime
  cutoffAt  DateTime
  isOpen    Boolean  @default(true)
  jackpot        String?
  winningMain       String?
  winningSpecial    String?
  resultAnnouncedAt DateTime?
  createdAt         DateTime @default(now())

  orders Order[]
}

model Order {
  id          String      @id @default(cuid())
  orderNumber Int         @default(autoincrement())
  userId      String
  drawId      String
  status      OrderStatus @default(PENDING_PAYMENT)
  totalUSD    Decimal     @db.Decimal(10, 2)
  totalTHB    Decimal     @db.Decimal(12, 2)
  rateUsed  Decimal     @db.Decimal(10, 4)
  note      String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user    User        @relation(fields: [userId], references: [id])
  draw    Draw        @relation(fields: [drawId], references: [id])
  items   OrderItem[]
  payment Payment?
  commission Commission?
}

model OrderItem {
  id             String    @id @default(cuid())
  orderId        String
  mainNumbers    String
  specialNumber  String
  ticketPhotoUrl String?
  ocrRawText     String?
  matchedAt      DateTime?
  createdAt      DateTime  @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Payment {
  id         String        @id @default(cuid())
  orderId    String        @unique
  slipUrl    String
  method     String        @default("SLIP")
  status     PaymentStatus @default(PENDING)
  approvedAt DateTime?
  approvedBy String?
  rejectedAt DateTime?
  rejectNote String?
  createdAt  DateTime      @default(now())

  slipSenderName    String?
  slipAmount        Decimal?  @db.Decimal(12, 2)
  slipAmountMatches Boolean?
  slipOcrNote       String?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model ExchangeRate {
  id        String   @id @default(cuid())
  date      DateTime @unique @db.Date
  usdToThb  Decimal  @db.Decimal(10, 4)
  source    String   @default("exchangerate-api.com")
  fetchedAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ReferrerProfile {
  userId       String   @id
  referralCode String   @unique
  createdAt    DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  commissions Commission[] @relation("ReferrerCommissions")
}

model UserReferral {
  userId         String   @id
  referrerUserId String
  referralCode   String
  createdAt      DateTime @default(now())

  user     User @relation("ReferredUser", fields: [userId], references: [id], onDelete: Cascade)
  referrer User @relation("ReferrerUser", fields: [referrerUserId], references: [id])
}

enum CommissionStatus {
  PENDING
  APPROVED
  CANCELLED
  PAID
}

model Commission {
  id               String           @id @default(cuid())
  orderId          String           @unique
  referrerUserId   String
  referredUserId   String
  amountTHB        Decimal          @db.Decimal(12, 2)
  rate             Decimal          @db.Decimal(5, 2) @default(50)
  profitTHB        Decimal          @db.Decimal(12, 2) @default(0)
  platformShareTHB Decimal          @db.Decimal(12, 2) @default(0)
  status           CommissionStatus @default(PENDING)
  createdAt        DateTime         @default(now())
  approvedAt       DateTime?
  paidAt           DateTime?
  paidBy           String?
  paidNote         String?

  order   Order          @relation(fields: [orderId], references: [id])
  referrer ReferrerProfile @relation("ReferrerCommissions", fields: [referrerUserId], references: [userId])
}

enum AuditAction {
  PAYMENT_APPROVED
  PAYMENT_REJECTED
  ORDER_DELETED
  MEMBER_DELETED
  MEMBER_MADE_REFERRER
  DRAW_CREATED
  RESULT_POSTED
  COMMISSION_PAID
  ORDERS_RESET
}

model WalletTransaction {
  id        String   @id @default(cuid())
  userId    String
  type      String
  amount    Decimal  @db.Decimal(12, 2)
  balanceAfter Decimal @db.Decimal(12, 2)
  note      String?
  createdBy String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String      @id @default(cuid())
  adminId    String
  action     AuditAction
  targetId   String?
  targetType String?
  note       String?
  createdAt  DateTime    @default(now())

  admin User @relation("AuditAdmin", fields: [adminId], references: [id])
}
