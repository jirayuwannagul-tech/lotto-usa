generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CUSTOMER
  ADMIN
}

enum DrawType {
  POWERBALL
  MEGA_MILLIONS
}

enum OrderStatus {
  PENDING_PAYMENT
  PENDING_APPROVAL
  APPROVED
  TICKET_UPLOADED
  MATCHED
  REJECTED
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  phone        String?
  lineId       String?
  passwordHash String
  role         Role     @default(CUSTOMER)
  createdAt    DateTime @default(now())

  orders Order[]
}

model Draw {
  id        String   @id @default(cuid())
  type      DrawType
  drawDate  DateTime
  cutoffAt  DateTime
  isOpen    Boolean  @default(true)
  jackpot        String?
  winningMain    String?
  winningSpecial String?
  createdAt      DateTime @default(now())

  orders Order[]
}

model Order {
  id        String      @id @default(cuid())
  userId    String
  drawId    String
  status    OrderStatus @default(PENDING_PAYMENT)
  totalUSD  Decimal     @db.Decimal(10, 2)
  totalTHB  Decimal     @db.Decimal(12, 2)
  rateUsed  Decimal     @db.Decimal(10, 4)
  note      String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user    User        @relation(fields: [userId], references: [id])
  draw    Draw        @relation(fields: [drawId], references: [id])
  items   OrderItem[]
  payment Payment?
}

model OrderItem {
  id             String    @id @default(cuid())
  orderId        String
  mainNumbers    String
  specialNumber  String
  ticketPhotoUrl String?
  ocrRawText     String?
  matchedAt      DateTime?
  createdAt      DateTime  @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Payment {
  id         String        @id @default(cuid())
  orderId    String        @unique
  slipUrl    String
  status     PaymentStatus @default(PENDING)
  approvedAt DateTime?
  approvedBy String?
  rejectedAt DateTime?
  rejectNote String?
  createdAt  DateTime      @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model ExchangeRate {
  id        String   @id @default(cuid())
  date      DateTime @unique @db.Date
  usdToThb  Decimal  @db.Decimal(10, 4)
  source    String   @default("exchangerate-api.com")
  fetchedAt DateTime @default(now())
}
